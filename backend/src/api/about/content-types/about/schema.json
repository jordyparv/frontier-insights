    "story_text_2": { "type": "richtext" },

    "story_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },

    "philosophy": {
      "type": "component",
      "repeatable": true,
      "component": "shared.value"
    },

    "timeline": {
      "type": "component",
      "repeatable": true,
      "component": "shared.timeline"
    },

    "cta_text": { "type": "string" },
    "cta_button": { "type": "string" }
  }
