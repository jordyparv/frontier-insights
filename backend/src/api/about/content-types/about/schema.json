  "kind": "singleType",
  "collectionName": "about",
  "info": {
    "singularName": "about",
    "pluralName": "abouts",
    "displayName": "About Page"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "hero_title": { "type": "string" },
    "hero_subtitle": { "type": "text" },
    "hero_label": { "type": "string" },

    "story_title": { "type": "string" },
