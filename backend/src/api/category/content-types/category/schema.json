{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Category"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "description": {
      "type": "text"
    },
    "podcasts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::podcast.podcast",
      "mappedBy": "category"
    },
    "magazines": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::magazine.magazine",
      "mappedBy": "category"
    }
  }
}
